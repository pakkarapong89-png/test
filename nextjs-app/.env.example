# ============================================================
# ไฟล์ตัวอย่างตัวแปรสภาพแวดล้อม (.env.example)
# คัดลอกไฟล์นี้ไปเป็น .env แล้วกรอกข้อมูลให้ครบทุกช่อง
# ============================================================

# --- ฐานข้อมูล (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://[user]:[password]@[host]:[port]/postgres"

# --- Jira Cloud ---
JIRA_DOMAIN="your-company.atlassian.net"
JIRA_EMAIL="your-jira-email@company.com"
JIRA_API_TOKEN="your-jira-api-token"
JIRA_PROJECT_KEY="YOUR_PROJECT_KEY"

# --- Google Chat Webhook (สำหรับส่งการแจ้งเตือน) ---
GOOGLE_CHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/..."

# --- AI (Google Gemini) ---
LLM_PROVIDER="gemini"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.5-flash"

# --- ชื่อแชทบอท (ต้องตรงกับ App name ใน Google Cloud Console) ---
BOT_NAME="taskyapp"

# --- ความปลอดภัย (สร้างอัตโนมัติโดย setup.js) ---
SESSION_SECRET="random-secret-at-least-32-characters"
CRON_SECRET="random-secret-16-characters"
